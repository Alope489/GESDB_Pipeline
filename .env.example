# Copy this file to .env and fill in your keys. Do not commit .env.

# OpenAI (article processing, LLM extraction)
OPENAI_API_KEY=

# Google Custom Search (optional; used in data_insert)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ENGINE_ID=

# Web search API (for future filler; e.g. Serper or SerpAPI)
# SERPER_API_KEY=
# SEARCH_API_KEY=

# Optional: corporate proxy
# HTTP_PROXY=
# HTTPS_PROXY=
